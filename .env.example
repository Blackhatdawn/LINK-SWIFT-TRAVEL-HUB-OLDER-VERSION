# Runtime mode
NODE_ENV="development"

# Backend server
PORT="3000"

# JWT secret for API and Socket auth (required in all environments)
JWT_SECRET="change_me_to_a_long_random_secret"

# Comma-separated list of allowed web origins for API CORS and Socket.io, e.g. "http://localhost:3000,https://app.example.com"
CLIENT_ORIGINS="http://localhost:3000"

# MongoDB connection string (required in production)
# In development only, app will fallback to mongodb-memory-server when omitted.
MONGO_URI="mongodb://127.0.0.1:27017/linkswift"

# Paystack (required in production for real payments and webhook signature verification)
PAYSTACK_SECRET_KEY="sk_test_change_me"

# Existing AI Studio-related values
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
